# ─── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── AI / Gemini ───────────────────────────────────────────────
API_URL=https://intertest.woolf.engineering/invoke
AUTH_TOKEN=your_auth_token_here

# ─── Supabase (server-side) ────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Keep secret! Never expose to client

# ─── Database (Supabase PostgreSQL) ───────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_HOURLY_MAX=300

# ─── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf
